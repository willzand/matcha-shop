# ══════════════════════════════════════════════════
# 🍵 Matcha Shop — Environment Variables
# ══════════════════════════════════════════════════

# ── Supabase (supabase.com → Settings → API) ──────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...     # "service_role" key (ไม่ใช่ anon!)

# ── LINE (developers.line.biz) ────────────────────
LINE_TOKEN=your-channel-access-token
LINE_CHANNEL_ID=2009818831

# ── Google Sheets Catalog ─────────────────────────
# Sheet ID จาก URL: docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# ⚠️ Sheet ต้องตั้งเป็น "Anyone with the link can view" (ไม่ต้อง API key)
CATALOG_SHEET_ID=14CuVpLM4QuyTLwo5ox8HwV83X0A4Z5TVi9CuK7p-Ygo

# ── Admin Password ─────────────────────────────────
# สร้าง hash:
#   node -e "const{createHash}=require('crypto');console.log(createHash('sha256').update('รหัสผ่าน'+'saltนี้').digest('hex'))"
PASS_SALT=random-secret-string
ADMIN_PASS_HASH=<sha256 output>
